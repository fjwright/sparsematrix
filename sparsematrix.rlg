% Lipschutz examples using generic mateigen:
s := sparsify mat((4,1,-1),(2,5,-2),(1,1,2));


*** 3 × 3 sparse matrix — 9 nonzero elements: 

s(1,1) := 4

s(1,2) := 1

s(1,3) := -1

s(2,1) := 2

s(2,2) := 5

s(2,3) := -2

s(3,1) := 1

s(3,2) := 1

s(3,3) := 2

mateigen(s, lam);



*** 3 × 1 sparse matrix — 3 nonzero elements: 
{{lam - 3,2,

  ?(1,1) := arbcomplex(8) - arbcomplex(7)

  ?(2,1) := arbcomplex(7)

  ?(3,1) := arbcomplex(8)

*** 3 × 1 sparse matrix — 3 nonzero elements: 
  },{lam - 5,1,

     ?(1,1) := arbcomplex(9)

     ?(2,1) := 2*arbcomplex(9)

     ?(3,1) := arbcomplex(9)
     }}

s := sparsify mat((3,-1,1),(7,-5,1),(6,-6,2));


*** 3 × 3 sparse matrix — 9 nonzero elements: 

s(1,1) := 3

s(1,2) := -1

s(1,3) := 1

s(2,1) := 7

s(2,2) := -5

s(2,3) := 1

s(3,1) := 6

s(3,2) := -6

s(3,3) := 2

mateigen(s, lam);



*** 3 × 1 sparse matrix — 2 nonzero elements: 
{{lam - 2,2,

  ?(1,1) := arbcomplex(10)

  ?(2,1) := arbcomplex(10)

*** 3 × 1 sparse matrix — 2 nonzero elements: 
  },{lam + 4,1,

     ?(2,1) := arbcomplex(11)

     ?(3,1) := arbcomplex(11)
     }}


% Mixed matrix types in algebraic expressions:


m := mat((1,2),(3,4));


     [1  2]
m := [    ]
     [3  4]


s := sparsify m;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

s(1,1) := 1

s(1,2) := 2

s(2,1) := 3

s(2,2) := 4


sparse_matrix_auto_convert_type();


dense

(2s+m)*m;


[21  30]
[      ]
[45  66]


(2m+s)^2;


[63   90 ]
[        ]
[135  198]



sparse_matrix_auto_convert_type sparse;


dense

(2s+m)*m;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := 21

?(1,2) := 30

?(2,1) := 45

?(2,2) := 66

(2m+s)^2;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := 63

?(1,2) := 90

?(2,1) := 135

?(2,2) := 198


sparse_matrix_auto_convert_type none;


sparse

(2s+m)*m;


***** 

