     [a  b]
m := [    ]
     [c  d]



sparsify m;


[a  b]
[    ]
[c  d]



s := ws;


     [a  b]
s := [    ]
     [c  d]



% Implicit mapping:
abs s;


[abs(a)  abs(b)]
[              ]
[abs(c)  abs(d)]


depend {a,b,c,d}, x;


df(s,x);


[df(a,x)  df(b,x)]
[                ]
[df(c,x)  df(d,x)]



% Substitution:
sub(a=aa,s);


[aa  b]
[     ]
[c   d]



