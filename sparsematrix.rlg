s := sparsify m;


     [1  2  3]
     [       ]
s := [4  5  6]
     [       ]
     [7  8  9]


det m;


0

sparse_det s;


0

det s;


0

m := mat((a,b,c),(d,e,f),(g,h,i));


     [a  b  c]
     [       ]
m := [d  e  f]
     [       ]
     [g  h  i]


s := sparsify m;


     [a  b  c]
     [       ]
s := [d  e  f]
     [       ]
     [g  h  i]


det m;


a*e*i - a*f*h - b*d*i + b*f*g + c*d*h - c*e*g

sparse_det s;


a*e*i - a*f*h - b*d*i + b*f*g + c*d*h - c*e*g

det s;


a*e*i - a*f*h - b*d*i + b*f*g + c*d*h - c*e*g

if det m = det s then "OK" else "***** ERROR *****";


OK


