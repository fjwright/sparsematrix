        % not advertised!

% Cofactors:
sparse_cofactor(s,1,1);


e*i - f*h

cofactor(s,1,1);


e*i - f*h

% Determinant via cofactors of first row:
for j := 1 : 3 sum s(1,j)*cofactor(s,1,j);


a*e*i - a*f*h - b*d*i + b*f*g + c*d*h - c*e*g

if ws = det s then "OK" else "***** ERROR *****";


OK


