on errcont;



sparse_matrix sd(5,5);



length sd;


{5,5}


sd;


*** 5 × 5 sparse matrix — no nonzero elements 


for i := 1:5 do sd(i,i) := i;



sd;


*** 5 × 5 sparse matrix — 5 nonzero elements: 

sd(1,1) := 1

sd(2,2) := 2

sd(3,3) := 3

sd(4,4) := 4

sd(5,5) := 5


for i := 1:5 do write sd(i,i) := sd(i,i);


sd(1,1) := 1

sd(2,2) := 2

sd(3,3) := 3

sd(4,4) := 4

sd(5,5) := 5


densify sd;


[1  0  0  0  0]
[             ]
[0  2  0  0  0]
[             ]
[0  0  3  0  0]
[             ]
[0  0  0  4  0]
[             ]
[0  0  0  0  5]



m := mat((a,b),(c,d));


     [a  b]
m := [    ]
     [c  d]



sparsify m;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := a

?(1,2) := b

?(2,1) := c

?(2,2) := d


s := ws;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

s(1,1) := a

s(1,2) := b

s(2,1) := c

s(2,2) := d


% Aggregate property:
abs s;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := abs(a)

?(1,2) := abs(b)

?(2,1) := abs(c)

?(2,2) := abs(d)

depend {a,b,c,d}, x;


df(s,x);


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := df(a,x)

?(1,2) := df(b,x)

?(2,1) := df(c,x)

?(2,2) := df(d,x)


% Substitution:
sub(a=aa,s);


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := aa

?(1,2) := b

?(2,1) := c

?(2,2) := d


sparse_random_matrix sr(5,5);



% Trace:
sparse_trace sr;


242


densify sr;


[0   0   0   0   22]
[                  ]
[0   0   0   0   0 ]
[                  ]
[0   0   0  805  0 ]
[                  ]
[0   0   0  242  0 ]
[                  ]
[0  351  0   0   0 ]



% Transpose:
densify sparse_tp sr;


[0   0   0    0    0 ]
[                    ]
[0   0   0    0   351]
[                    ]
[0   0   0    0    0 ]
[                    ]
[0   0  805  242   0 ]
[                    ]
[22  0   0    0    0 ]



% Determinant:
m := mat((a,b,c),(d,e,f),(g,h,i));


     [a  b  c]
     [       ]
m := [d  e  f]
     [       ]
     [g  h  i]


s := sparsify m;


*** 3 × 3 sparse matrix — 9 nonzero elements: 

s(1,1) := a

s(1,2) := b

s(1,3) := c

s(2,1) := d

s(2,2) := e

s(2,3) := f

s(3,1) := g

s(3,2) := h

s(3,3) := i

det m;


a*e*i - a*f*h - b*d*i + b*f*g + c*d*h - c*e*g

sparse_det s;


a*e*i - a*f*h - b*d*i + b*f*g + c*d*h - c*e*g

if det m = sparse_det s then "OK" else "***** ERROR *****";


OK


% Addition and scalar multiplication:
m1 := mat((a,b),(c,d));


      [a  b]
m1 := [    ]
      [c  d]


m2 := mat((e,f),(g,h));


      [e  f]
m2 := [    ]
      [g  h]


s1 := sparsify m1;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

s1(1,1) := a

s1(1,2) := b

s1(2,1) := c

s1(2,2) := d

s2 := sparsify m2;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

s2(1,1) := e

s2(1,2) := f

s2(2,1) := g

s2(2,2) := h

% symbolic;
% global '(ss1 ss2 ss);
% ss1 := sparse!-matsm 's1;
% ss2 := sparse!-matsm 's2;
% ss := sparse!-addm(ss1,ss2);
% sparse!-matpri sparse!-matsm!*1 ss;
m1 + m2;


[a + e  b + f]
[            ]
[c + g  d + h]


s1 + s2;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := a + e

?(1,2) := b + f

?(2,1) := c + g

?(2,2) := d + h

2m1 + 3m2;


[2*a + 3*e  2*b + 3*f]
[                    ]
[2*c + 3*g  2*d + 3*h]


2s1 + 3s2;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := 2*a + 3*e

?(1,2) := 2*b + 3*f

?(2,1) := 2*c + 3*g

?(2,2) := 2*d + 3*h


% Matrix multiplication:
m3 := mat((a,b,c),(d,e,f));


      [a  b  c]
m3 := [       ]
      [d  e  f]


m4 := mat((g,h),(i,j),(k,l));


      [g  h]
      [    ]
m4 := [i  j]
      [    ]
      [k  l]


s3 := sparsify m3;


*** 2 × 3 sparse matrix — 6 nonzero elements: 

s3(1,1) := a

s3(1,2) := b

s3(1,3) := c

s3(2,1) := d

s3(2,2) := e

s3(2,3) := f

s4 := sparsify m4;


*** 3 × 2 sparse matrix — 6 nonzero elements: 

s4(1,1) := g

s4(1,2) := h

s4(2,1) := i

s4(2,2) := j

s4(3,1) := k

s4(3,2) := l

m3*m4;


[a*g + b*i + c*k  a*h + b*j + c*l]
[                                ]
[d*g + e*i + f*k  d*h + e*j + f*l]


s3*s4;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

?(1,1) := a*g + b*i + c*k

?(1,2) := a*h + b*j + c*l

?(2,1) := d*g + e*i + f*k

?(2,2) := d*h + e*j + f*l


m4*m3;


[a*g + d*h  b*g + e*h  c*g + f*h]
[                               ]
[a*i + d*j  b*i + e*j  c*i + f*j]
[                               ]
[a*k + d*l  b*k + e*l  c*k + f*l]


s4*s3;


*** 3 × 3 sparse matrix — 9 nonzero elements: 

?(1,1) := a*g + d*h

?(1,2) := b*g + e*h

?(1,3) := c*g + f*h

?(2,1) := a*i + d*j

?(2,2) := b*i + e*j

?(2,3) := c*i + f*j

?(3,1) := a*k + d*l

?(3,2) := b*k + e*l

?(3,3) := c*k + f*l


2m1*m3*m4;


         2
mat((2*(a *g + a*b*i + a*c*k + b*d*g + b*e*i + b*f*k),

         2
     2*(a *h + a*b*j + a*c*l + b*d*h + b*e*j + b*f*l)),

                         2      2
    (2*(a*c*g + b*c*i + c *k + d *g + d*e*i + d*f*k),

                         2      2
     2*(a*c*h + b*c*j + c *l + d *h + d*e*j + d*f*l)))


2s1*s3*s4;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

              2
?(1,1) := 2*(a *g + a*b*i + a*c*k + b*d*g + b*e*i + b*f*k)

              2
?(1,2) := 2*(a *h + a*b*j + a*c*l + b*d*h + b*e*j + b*f*l)

                              2      2
?(2,1) := 2*(a*c*g + b*c*i + c *k + d *g + d*e*i + d*f*k)

                              2      2
?(2,2) := 2*(a*c*h + b*c*j + c *l + d *h + d*e*j + d*f*l)


m3*m4*m1*3;


         2                                      2
mat((3*(a *g + a*b*i + a*c*h + a*c*k + b*c*j + c *l),

                         2
     3*(a*b*g + a*d*h + b *i + b*c*k + b*d*j + c*d*l)),

    (3*(a*d*g + a*e*i + a*f*k + c*d*h + c*e*j + c*f*l),

                                 2
     3*(b*d*g + b*e*i + b*f*k + d *h + d*e*j + d*f*l)))


s3*s4*s1*3;


*** 2 × 2 sparse matrix — 4 nonzero elements: 

              2                                      2
?(1,1) := 3*(a *g + a*b*i + a*c*h + a*c*k + b*c*j + c *l)

                              2
?(1,2) := 3*(a*b*g + a*d*h + b *i + b*c*k + b*d*j + c*d*l)

?(2,1) := 3*(a*d*g + a*e*i + a*f*k + c*d*h + c*e*j + c*f*l)

                                      2
?(2,2) := 3*(b*d*g + b*e*i + b*f*k + d *h + d*e*j + d*f*l)


