% symbolic;
% global '(ss1 ss2 ss);
% ss1 := sparse!-matsm 's1;
% ss2 := sparse!-matsm 's2;
% ss := sparse!-addm(ss1,ss2);
% sparse!-matpri sparse!-matsm!*1 ss;
m1 + m2;


[a + e  b + f]
[            ]
[c + g  d + h]


s1 + s2;


[a + e  b + f]
[            ]
[c + g  d + h]


2m1 + 3m2;


[2*a + 3*e  2*b + 3*f]
[                    ]
[2*c + 3*g  2*d + 3*h]


2s1 + 3s2;


[2*a + 3*e  2*b + 3*f]
[                    ]
[2*c + 3*g  2*d + 3*h]



